{
  "permissions": {
    "allow": [
      "Bash(find '/Users/alfonso.garciamateo-sagasta/Documents/Plain Concepts/Formaciones/Anthropic Short Courses/2. Claude Code/uigen' -maxdepth 2 -name CLAUDE.md -o -name .cursorrules -o -name *.md -type f)",
      "Bash(npm run:*)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_click"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/hooks/read_hook.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command", 
            "command": "node /home/hooks/edit_hook.ts"
          }
        ]
      }
    ]
  }
}
